@model Author
@{
    ViewData["Title"] = "Добави автор";
}

<div class="form-card">
    <h1>✍️ Нов автор</h1>
    <form asp-action="Create">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
        <div class="form-group">
            <label asp-for="Name"></label>
            <input asp-for="Name" class="form-control" placeholder="Пълно име" />
            <span asp-validation-for="Name" class="field-error"></span>
        </div>
        <div class="form-group">
            <label asp-for="Bio"></label>
            <textarea asp-for="Bio" class="form-control" rows="3" placeholder="Кратка биография (незадължително)"></textarea>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Запази</button>
            <a asp-action="Index" class="btn">Отказ</a>
        </div>
    </form>
</div>
