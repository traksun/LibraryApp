<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – Онлайн Библиотека</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Source+Sans+3:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <nav class="navbar">
        <div class="nav-inner">
            <a class="nav-brand" asp-controller="Home" asp-action="Index">
                <span class="brand-icon">📚</span>
                <span>Библиотека</span>
            </a>
            <div class="nav-links">
                <a asp-controller="Home" asp-action="Index">Начало</a>
                <a asp-controller="Books" asp-action="Index">Книги</a>
                <a asp-controller="Authors" asp-action="Index">Автори</a>
                <a asp-controller="Categories" asp-action="Index">Категории</a>
            </div>
        </div>
    </nav>

    <main class="main-content">
        @RenderBody()
    </main>

    <footer class="footer">
        <p>© @DateTime.Now.Year Онлайн Библиотека &nbsp;·&nbsp; ASP.NET Core + Entity Framework Core</p>
    </footer>
</body>
</html>
