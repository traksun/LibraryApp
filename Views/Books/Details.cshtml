@model Book
@{
    ViewData["Title"] = Model.Title;
}

<div class="detail-card">
    <div class="detail-header">
        <h1>@Model.Title</h1>
        <span class="detail-year">@Model.Year</span>
    </div>

    <div class="detail-body">
        <div class="detail-row">
            <span class="detail-label">Автор</span>
            <span class="detail-value">
                <a asp-controller="Authors" asp-action="Details" asp-route-id="@Model.AuthorId">@Model.Author?.Name</a>
            </span>
        </div>

        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <div class="detail-row">
                <span class="detail-label">Описание</span>
                <span class="detail-value">@Model.Description</span>
            </div>
        }

        <div class="detail-row">
            <span class="detail-label">Категории</span>
            <span class="detail-value">
                @foreach (var bc in Model.BookCategories)
                {
                    <span class="badge">@bc.Category?.Name</span>
                }
            </span>
        </div>
    </div>

    <div class="detail-actions">
        <a asp-action="Edit" asp-route-id="@Model.BookId" class="btn btn-edit">Редактирай</a>
        <a asp-action="Index" class="btn">Назад</a>
    </div>
</div>
